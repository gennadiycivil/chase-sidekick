# Atlassian Configuration (works for both JIRA and Confluence)
#
# Option 1: OAuth2 (recommended — tokens auto-refresh, no manual renewal):
# 1. Create OAuth 2.0 (3LO) app at https://developer.atlassian.com/console/myapps/
# 2. Add callback URL: http://localhost:8901/callback
# 3. Add permissions: read:jira-work, write:jira-work, read:jira-user
# 4. Run: python3 tools/get_atlassian_refresh_token.py
ATLASSIAN_CLIENT_ID=your_client_id_here
ATLASSIAN_CLIENT_SECRET=your_client_secret_here
ATLASSIAN_REFRESH_TOKEN=your_refresh_token_here
ATLASSIAN_CLOUD_ID=your_cloud_id_here
#
# Option 2: Basic Auth (legacy — API tokens expire after ~1 year):
# Get API token: https://id.atlassian.com/manage-profile/security/api-tokens
# ATLASSIAN_URL=https://your-company.atlassian.net
# ATLASSIAN_EMAIL=your-email@company.com
# ATLASSIAN_API_TOKEN=your_api_token_here

# User Configuration (for 1:1 docs and personalized features)
USER_NAME=Chase
USER_EMAIL=your-email@company.com

# Team Group Configuration (optional)
# Define team groups for organized querying and reporting
# Format: <GROUPNAME>_GROUP_PROJECTS for comma-separated project keys
# Optional: <GROUPNAME>_GROUP_JQL for custom JQL (auto-generated if not provided)
TEAMS_GROUP_PROJECTS=PROJ1,PROJ2,PROJ3
TEAMS_GROUP_JQL=project IN ("PROJ1", "PROJ2", "PROJ3")

# OmniFocus Configuration (optional, macOS only)
# Default tag for task creation
OMNIFOCUS_DEFAULT_TAG=from-cli

# Dropbox Configuration
# 1. Create an app at https://www.dropbox.com/developers/apps with "Full Dropbox" access
# 2. Go to Permissions tab and enable: files.content.read, files.content.write, sharing.read
# 3. Note your App key and App secret from the Settings tab
# 4. Run: python3 tools/get_dropbox_refresh_token.py to get a refresh token
#
# Refresh token flow (recommended — tokens auto-refresh, no manual renewal):
DROPBOX_APP_KEY=your_app_key_here
DROPBOX_APP_SECRET=your_app_secret_here
DROPBOX_REFRESH_TOKEN=your_refresh_token_here
#
# Legacy: static access token (expires after ~4 hours):
# DROPBOX_ACCESS_TOKEN=your_dropbox_access_token_here

# Google Services Configuration (Gmail, Calendar, Sheets)
# Get credentials from Google Cloud Console: https://console.cloud.google.com/
# 1. Create OAuth2 credentials (Desktop app)
# 2. Enable APIs: Gmail API, Google Calendar API, Google Sheets API, Google Drive API
# 3. Get refresh token with combined scopes (run: python3 tools/get_google_refresh_token.py)
# Note: Use combined scopes when generating refresh token:
#   - https://www.googleapis.com/auth/gmail.modify
#   - https://www.googleapis.com/auth/calendar
#   - https://www.googleapis.com/auth/spreadsheets
#   - https://www.googleapis.com/auth/drive.readonly (for listing spreadsheets)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# Slack Configuration
# Get bot token: https://api.slack.com/apps
# 1. Create a new app (from scratch)
# 2. Go to OAuth & Permissions
# 3. Add Bot Token Scopes: channels:history, channels:read, groups:history,
#    groups:read, users:read, users:read.email
# 4. Install to workspace
# 5. Copy Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
